    <SolidColorBrush x:Key="Zenvix.Surface" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Zenvix.Card" Color="#F9FAFB" />
    <SolidColorBrush x:Key="Zenvix.Border" Color="#E5E7EB" />
    <SolidColorBrush x:Key="Zenvix.BorderGlow" Color="#D1D5DB" />
    
    <SolidColorBrush x:Key="Zenvix.Accent" Color="#6366F1" />
    <SolidColorBrush x:Key="Zenvix.AccentHover" Color="#4F46E5" />
    <SolidColorBrush x:Key="Zenvix.AccentGlow" Color="#C7D2FE" />
    
    <SolidColorBrush x:Key="Zenvix.TextPrimary" Color="#111827" />
    <SolidColorBrush x:Key="Zenvix.TextSecondary" Color="#4B5563" />
    <SolidColorBrush x:Key="Zenvix.TextMuted" Color="#9CA3AF" />

    <SolidColorBrush x:Key="Zenvix.Success" Color="#10B981" />
    <SolidColorBrush x:Key="Zenvix.SuccessBg" Color="#D1FAE5" />
    
    <SolidColorBrush x:Key="Zenvix.Warning" Color="#F59E0B" />
    <SolidColorBrush x:Key="Zenvix.WarningBg" Color="#FEF3C7" />
    
    <SolidColorBrush x:Key="Zenvix.Danger" Color="#EF4444" />
    <SolidColorBrush x:Key="Zenvix.DangerBg" Color="#FEE2E2" />

