<mah:MetroWindow x:Class="Hostix.UI.Views.CustomAlertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:ds="clr-namespace:Zenvix.DesignSystem"
        Title="{Binding AlertTitle}" Height="260" Width="460"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource Zenvix.Background}"
        BorderThickness="1" BorderBrush="{StaticResource Zenvix.Border}"
        GlowBrush="{StaticResource Zenvix.BorderGlow}"
        TitleCharacterCasing="Normal"
        TitleAlignment="Left">
    
    <Grid>
        <StackPanel Margin="32,24" VerticalAlignment="Center">
            <!-- Icon & Dynamic Title -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <!-- SVG Icon rendering via static resource path -->
                <Path Data="{StaticResource HeroIcon.Shield}" Fill="{Binding IconColor}" Width="32" Height="32" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,16,0" />
                <TextBlock Text="{Binding AlertTitle}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Zenvix.TextPrimary}" VerticalAlignment="Center" />
            </StackPanel>
            
            <!-- Message Body -->
            <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20" Foreground="{StaticResource Zenvix.TextSecondary}" Margin="0,0,0,24" Height="70" VerticalAlignment="Top">
                <Run Text="{Binding AlertMessage, Mode=OneWay}" />
            </TextBlock>

            <!-- Actions Row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>
                
                <ds:ZenvixButton Grid.Column="1" Content="Dismiss" Command="{Binding CloseAlertCommand}" 
                        Style="{StaticResource ZenvixButton.Primary}" Height="40" FontSize="13" FontWeight="SemiBold"
                        IsDefault="True" />
            </Grid>
            
        </StackPanel>
    </Grid>
</mah:MetroWindow>
