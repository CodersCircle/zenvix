<UserControl x:Class="Hostix.UI.Views.WebsitesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:models="clr-namespace:Hostix.Core.Models;assembly=Hostix.Core"
    xmlns:conv="clr-namespace:Hostix.UI.Converters"
    mc:Ignorable="d"
    d:DesignHeight="800" d:DesignWidth="1100">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <conv:StatusToColorConverter x:Key="StatusToColorConverter" />
        <conv:StatusToButtonTextConverter x:Key="StatusToButtonTextConverter" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        
        <Style x:Key="ActionIconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <!-- Modern Card Style -->
        <Style x:Key="WebsiteCardStyle" TargetType="Border" BasedOn="{StaticResource Hostix.Card}">
            <Setter Property="Background" Value="{DynamicResource CardBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 1. Header Area -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="Websites" Style="{DynamicResource Hostix.Title}" />
                <TextBlock Text="Local project management and orchestration" 
                           Style="{DynamicResource Hostix.Subtitle}" />
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Command="{Binding ShowAddWebsiteCommand}"
                        Style="{DynamicResource Hostix.Button.Primary}" Height="36" Padding="20,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="14" />
                        <TextBlock Text="New Website" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 2. Websites Grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Websites}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="280" Margin="0,0,16,16" Background="{DynamicResource CardBrush}" 
                                CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                                SnapsToDevicePixels="True" Effect="{DynamicResource Hostix.Shadow.Small}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /> <!-- Header -->
                                    <RowDefinition Height="Auto" /> <!-- Body -->
                                    <RowDefinition Height="Auto" /> <!-- Tools -->
                                    <RowDefinition Height="Auto" /> <!-- Actions -->
                                </Grid.RowDefinitions>

                                <!-- 1. Status & Meta Row -->
                                <Border Grid.Row="0" Padding="16,16,16,8">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Status Badge -->
                                            <Border Padding="8,4" CornerRadius="12">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F1F5F9" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                <Setter Property="Background" Value="#F0FDF4" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="#94A3B8" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                        <Setter Property="Fill" Value="#22C55E" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#64748B" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                        <Setter Property="Foreground" Value="#15803D" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>

                                            <!-- SSL Toggle -->
                                            <mah:ToggleSwitch Style="{StaticResource Hostix.ToggleSwitch.Compact}"
                                                              IsOn="{Binding SslEnabled}" 
                                                              Command="{Binding DataContext.ToggleSslCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              CommandParameter="{Binding}"
                                                              OnContent="SSL" OffContent="SSL"
                                                              FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0" />
                                        </StackPanel>

                                        <!-- PHP Version Badge -->
                                        <Border HorizontalAlignment="Right" Background="#F8FAFC" Padding="8,4" CornerRadius="8">
                                            <TextBlock Text="{Binding PhpVersion, StringFormat='PHP {0}'}" FontSize="10" FontWeight="Bold" Foreground="#6366F1" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- 2. Project Identity -->
                                <Border Grid.Row="1" Padding="16,0,16,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Squircle Icon -->
                                        <Border Width="54" Height="54" CornerRadius="14" Background="{DynamicResource BackgroundBrush}" Margin="0,0,14,0">
                                            <TextBlock Text="{Binding Icon}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" 
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Black" Foreground="{DynamicResource TextPrimaryBrush}" MaxWidth="150" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center" ToolTip="SSL Secure">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                            <Setter Property="Opacity" Value="0.2" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SslEnabled}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                                    <Setter Property="Opacity" Value="1.0" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Domain}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- 3. Quick Tool Actions -->
                                <Border Grid.Row="2" Background="#05000000" BorderThickness="0,1" BorderBrush="{DynamicResource BorderBrush}" Padding="8,8">
                                    <UniformGrid Columns="4">
                                        <Button Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}" ToolTip="Open Folder" Style="{DynamicResource Hostix.Button.Ghost}" Height="34" Padding="0">
                                            <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                                        </Button>
                                        <Button Command="{Binding DataContext.OpenCodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}" ToolTip="Open in VS Code" Style="{DynamicResource Hostix.Button.Ghost}" Height="34" Padding="0">
                                            <TextBlock Text="&#xE799;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                                        </Button>
                                        <Button Command="{Binding DataContext.OpenTerminalCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}" ToolTip="Open Terminal" Style="{DynamicResource Hostix.Button.Ghost}" Height="34" Padding="0">
                                            <TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                                        </Button>
                                        <Button Command="{Binding DataContext.OpenSiteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}" ToolTip="Open Website" Height="34" Padding="0" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource Hostix.Button.Ghost}">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Running">
                                                            <Setter Property="IsEnabled" Value="True" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="&#xE890;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                                        </Button>
                                    </UniformGrid>
                                </Border>

                                <!-- 4. Primary Actions -->
                                <Border Grid.Row="3" Padding="16,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="10*" />
                                            <ColumnDefinition Width="8*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Run/Stop Button -->
                                        <Button Grid.Column="0" Command="{Binding DataContext.ToggleWebsiteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" IsEnabled="{Binding Status, Converter={StaticResource StatusToIsEnabledConverter}}"
                                                Height="42" Margin="0,0,8,0" Style="{StaticResource Hostix.Button.Blue}">
                                            <StackPanel Orientation="Horizontal">
                                                <mah:ProgressRing Width="14" Height="14" Margin="0,0,8,0" Foreground="White" 
                                                                  Visibility="{Binding Status, Converter={StaticResource StatusToSpinnerVisibilityConverter}}" />
                                                <TextBlock Text="{Binding Status, Converter={StaticResource StatusToButtonTextConverter}}" 
                                                           FontSize="13" FontWeight="Bold" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>

                                        <!-- Remove (Panel) Button -->
                                        <Button Grid.Column="1" Command="{Binding DataContext.DeleteWebsiteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}" Content="Remove" Style="{StaticResource Hostix.Button.Orange}" 
                                                Height="42" Margin="4,0,8,0" />

                                        <!-- Delete (Disk) Button -->
                                        <Button Grid.Column="2" Command="{Binding DataContext.DeleteWebsiteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}" ToolTip="Permanent Delete" Style="{DynamicResource Hostix.Button.Ghost}" 
                                                Width="42" Height="42" Padding="0">
                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource ErrorBrush}" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 3. Add Website Overlay (Themed) -->
        <Border Grid.RowSpan="2" Background="#88000000" Visibility="{Binding IsAddingWebsite, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Width="480" VerticalAlignment="Center" Padding="30" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Add New Website" Style="{DynamicResource Hostix.Title}" Margin="0,0,0,4" />
                    <TextBlock Text="Provision a new local site and virtual host." Style="{DynamicResource Hostix.Subtitle}" Margin="0,0,0,24" />
                    
                    <TextBlock Text="PROJECT NAME" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <TextBox Text="{Binding NewWebsiteName, UpdateSourceTrigger=PropertyChanged}" 
                             mah:TextBoxHelper.Watermark="e.g. My Website" 
                             mah:ControlsHelper.CornerRadius="8"
                             mah:ControlsHelper.FocusBorderBrush="{DynamicResource AccentBrush}"
                             mah:ControlsHelper.MouseOverBorderBrush="{DynamicResource AccentBrush}"
                             Background="{StaticResource SurfaceBrush}"
                             Foreground="Black"
                             BorderBrush="{StaticResource BorderBrush}"
                             Height="38" Margin="0,0,0,16" Padding="10,0" VerticalContentAlignment="Center" />

                    <TextBlock Text="LOCAL DOMAIN" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding NewWebsiteDomain, UpdateSourceTrigger=PropertyChanged}" 
                                 mah:TextBoxHelper.Watermark="e.g. mysite.test" 
                                 mah:ControlsHelper.CornerRadius="8,0,0,8"
                                 mah:ControlsHelper.FocusBorderBrush="{DynamicResource AccentBrush}"
                                 mah:ControlsHelper.MouseOverBorderBrush="{DynamicResource AccentBrush}"
                                 Background="{StaticResource SurfaceBrush}"
                                 Foreground="Black"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 Height="38" Padding="10,0" VerticalContentAlignment="Center" />
                        <ComboBox Grid.Column="1" 
                                  ItemsSource="{Binding Suffixes}" 
                                  SelectedItem="{Binding SelectedSuffix}"
                                  mah:ControlsHelper.CornerRadius="0,8,8,0"
                                  Background="{StaticResource SurfaceBrush}"
                                  Foreground="Black"
                                  BorderThickness="0,1,1,1"
                                  BorderBrush="{StaticResource BorderBrush}"
                                  Height="38" VerticalContentAlignment="Center">
                            <ComboBox.Resources>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
                                    <Setter Property="Foreground" Value="Black" />
                                </Style>
                            </ComboBox.Resources>
                        </ComboBox>
                    </Grid>

                    <TextBlock Text="PARENT DIRECTORY" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding NewWebsitePath}" IsReadOnly="True" 
                                 mah:ControlsHelper.CornerRadius="8"
                                 mah:ControlsHelper.FocusBorderBrush="{DynamicResource AccentBrush}"
                                 mah:ControlsHelper.MouseOverBorderBrush="{DynamicResource AccentBrush}"
                                 Background="{StaticResource SurfaceBrush}"
                                 Foreground="Black"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 Height="38" FontSize="12" VerticalContentAlignment="Center" Padding="10,0" />
                        <Button Grid.Column="1" Command="{Binding BrowseFolderCommand}"
                                Content="Browse" Style="{DynamicResource Hostix.Button}" 
                                Height="38" Width="80" Margin="8,0,0,0" Padding="0" />
                    </Grid>
                    
                    <Border Background="{DynamicResource BackgroundBrush}" Padding="10" CornerRadius="6" Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Target Path: " FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding FullCreatedPathDisplay}" FontSize="10" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" />
                        </StackPanel>
                    </Border>

                    <mah:ToggleSwitch Header="Enable SSL (HTTPS)" IsOn="{Binding NewWebsiteSslEnabled}" 
                                      Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,24" 
                                      OnContent="Secure" OffContent="HTTP Only" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Command="{Binding CancelAddWebsiteCommand}" 
                                Style="{DynamicResource Hostix.Button.Ghost}" Margin="0,0,12,0" Width="90" Height="34" />
                        <Button Content="Provision" Command="{Binding CreateWebsiteCommand}" 
                                Style="{DynamicResource Hostix.Button.Primary}" Width="120" Height="34" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>