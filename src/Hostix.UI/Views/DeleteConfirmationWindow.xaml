<mah:MetroWindow x:Class="Hostix.UI.Views.DeleteConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:ds="clr-namespace:Zenvix.DesignSystem"
        Title="CONFIRM PROJECT DELETION" Height="380" Width="520"            
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource Zenvix.Background}" 
        BorderThickness="1" BorderBrush="{StaticResource Zenvix.Border}"
        GlowBrush="{StaticResource Zenvix.Danger}"
        TitleCharacterCasing="Normal"
        TitleAlignment="Left">
    
    <Grid>
        <StackPanel Margin="32,24">
            <!-- Warning Title -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <!-- SVG Icon rendering via crisp Hero Line Icon -->
                <Path Data="{StaticResource HeroIcon.Trash}" Stroke="{StaticResource Zenvix.Danger}" StrokeThickness="1.5" Fill="Transparent" Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0" />
                <TextBlock Text="Are you absolutely sure?" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource Zenvix.TextPrimary}" VerticalAlignment="Center" />
            </StackPanel>
            
            <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20" Foreground="{StaticResource Zenvix.TextSecondary}" Margin="0,0,0,24">
                This action <Run FontWeight="SemiBold" Foreground="{StaticResource Zenvix.Danger}">CANNOT</Run> be undone. 
                This will permanently remove <Run FontWeight="Medium" Foreground="{StaticResource Zenvix.TextPrimary}" Text="{Binding WebsiteName, Mode=OneWay}" /> 
                and delete all files from your disk.
            </TextBlock>

            <!-- Confirmation Helper Box -->
            <Border Background="{StaticResource Zenvix.Surface}" BorderBrush="{StaticResource Zenvix.Border}" BorderThickness="1" Padding="16,12" CornerRadius="12" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="Type name to confirm:" VerticalAlignment="Center" FontSize="13" FontWeight="Regular" Foreground="{StaticResource Zenvix.TextPrimary}" />
                    
                    <Border Grid.Column="1" Background="{StaticResource Zenvix.Card}" BorderBrush="{StaticResource Zenvix.Border}" BorderThickness="1" Padding="10,4" CornerRadius="8" HorizontalAlignment="Left" Margin="12,0">
                        <TextBlock Text="{Binding WebsiteName}" FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource Zenvix.Accent}" />
                    </Border>
                    
                    <Button Grid.Column="2" Content="COPY" Command="{Binding CopyNameCommand}" 
                            Style="{StaticResource ZenvixButton.Ghost}" Height="30" Padding="12,0" FontSize="11" FontWeight="SemiBold" />
                </Grid>
            </Border>

            <!-- Action Area (Input + Button) -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>
                
                <TextBox x:Name="ConfirmBox" Text="{Binding ConfirmationInput, UpdateSourceTrigger=PropertyChanged}" 
                          Style="{StaticResource ZenvixInput}"
                          mah:TextBoxHelper.Watermark="Verify website name..." 
                          Height="42" Padding="12,0" VerticalContentAlignment="Center" FontSize="13" Foreground="{StaticResource Zenvix.TextPrimary}" Margin="0,0,12,0" 
                          FontWeight="Regular" />

                <ds:ZenvixButton Grid.Column="1" Content="Delete" IsDefault="True" Command="{Binding ConfirmDeleteCommand}" 
                         Style="{StaticResource ZenvixButton}" Height="42" FontSize="13" FontWeight="Medium"
                         Background="{StaticResource Zenvix.Danger}" Foreground="White" BorderBrush="{StaticResource Zenvix.Danger}"
                         IsEnabled="{Binding IsConfirmEnabled}" />
            </Grid>
            
        </StackPanel>
    </Grid>
</mah:MetroWindow>
