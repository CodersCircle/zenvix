<UserControl x:Class="Hostix.UI.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:models="clr-namespace:Hostix.Core.Models;assembly=Hostix.Core"
    xmlns:conv="clr-namespace:Hostix.UI.Converters"
    mc:Ignorable="d"
    d:DesignHeight="1000" d:DesignWidth="1100">

    <UserControl.Resources>
        <conv:StatusToColorConverter x:Key="StatusToColorConverter" />
        <conv:StatusToButtonTextConverter x:Key="StatusToButtonTextConverter" />
        <conv:StatusToIsEnabledConverter x:Key="StatusToIsEnabledConverter" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <conv:StatusToVisibilityConverter x:Key="StatusToVisibilityConverter" />
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />

        <!-- ════════════════════════════════════════════════════════════
             Modern thin scrollbar — VS Code / Linear style
             ════════════════════════════════════════════════════════════ -->
        <Style x:Key="ModernScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="3"
                            Background="{DynamicResource TextSecondaryBrush}"
                            Opacity="0.35"
                            Margin="2">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.7" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernScrollBar" TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"
                                        Height="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ModernScrollBarThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"
                                        Height="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernScrollViewer" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="6" />
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"
                                CanContentScroll="{TemplateBinding CanContentScroll}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                Content="{TemplateBinding Content}" />
                            <ScrollBar Grid.Column="1"
                                x:Name="PART_VerticalScrollBar"
                                Style="{StaticResource ModernScrollBar}"
                                Value="{TemplateBinding VerticalOffset}"
                                Maximum="{TemplateBinding ScrollableHeight}"
                                ViewportSize="{TemplateBinding ViewportHeight}"
                                Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Outer ScrollViewer so the whole page is scrollable -->
    <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,10,24">

            <!-- 1. TOP METRICS -->
            <UniformGrid Columns="4" Margin="0,0,0,24">
                <Border Style="{DynamicResource Hostix.Card}" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="SYSTEM STATUS" Style="{DynamicResource Hostix.Subtitle}" />
                        <TextBlock
                            Text="{Binding DataContext.StatusText, RelativeSource={RelativeSource AncestorType=Window}}"
                            FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap"
                            Foreground="{DynamicResource AccentBrush}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource Hostix.Card}" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="CPU USAGE" Style="{DynamicResource Hostix.Subtitle}" />
                        <TextBlock Text="{Binding StateManager.CpuUsage}"
                            FontSize="15" FontWeight="SemiBold"
                            Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource Hostix.Card}" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="MEMORY" Style="{DynamicResource Hostix.Subtitle}" />
                        <TextBlock Text="{Binding StateManager.RamUsage}"
                            FontSize="15" FontWeight="SemiBold"
                            Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{DynamicResource Hostix.Card}">
                    <StackPanel>
                        <TextBlock Text="HEALTH MONITOR" Style="{DynamicResource Hostix.Subtitle}" />
                        <TextBlock Text="{Binding StateManager.SystemHealthStatus}"
                            FontSize="15" FontWeight="SemiBold"
                            Foreground="{DynamicResource SuccessBrush}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- 2. MAIN CONTENT AREA — Left + Right columns -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <!-- ===== LEFT COLUMN: Active Services ===== -->
                <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    CornerRadius="16" Padding="25" Margin="0,0,20,0"
                    VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Active Services" FontWeight="Bold" FontSize="16"
                            Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20" />

                        <ItemsControl ItemsSource="{Binding Services}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBrush}"
                                        CornerRadius="12"
                                        Margin="0,0,0,10" Padding="15"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1">
                                        <Grid>
                                            <!-- Left: status dot + name/port -->
                                            <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                                <Border Width="10" Height="10" CornerRadius="5"
                                                    VerticalAlignment="Center" Margin="0,0,12,0"
                                                    Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}" />
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource TextPrimaryBrush}" />
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Version}"
                                                            FontWeight="Bold" FontSize="11"
                                                            Foreground="{DynamicResource AccentBrush}"
                                                            Margin="0,0,6,0"
                                                            Visibility="{Binding Version, Converter={StaticResource StringToVisibilityConverter}}" />
                                                        <TextBlock Text="{Binding Status}"
                                                            FontSize="11"
                                                            Foreground="{DynamicResource TextSecondaryBrush}" />
                                                        <TextBlock Text=" • " FontSize="11"
                                                            Foreground="{DynamicResource TextSecondaryBrush}" />
                                                        <TextBlock
                                                            Text="{Binding Port, StringFormat='Port \{0\}'}"
                                                            FontSize="11"
                                                            Foreground="{DynamicResource TextSecondaryBrush}" />
                                                        
                                                        <!-- Mailpit secondary port -->
                                                        <StackPanel Orientation="Horizontal" Visibility="{Binding Type, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Mailpit}">
                                                            <TextBlock Text=" • " FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                                                            <TextBlock Text="Web UI 8025" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <!-- Detailed error/diagnostic notes - copyable -->
                                                    <TextBox Text="{Binding Notes, Mode=OneWay}"
                                                        FontSize="10"
                                                        Foreground="{DynamicResource ErrorBrush}"
                                                        Background="Transparent" BorderThickness="0"
                                                        IsReadOnly="True" TextWrapping="Wrap"
                                                        Margin="0,4,0,0">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox">
                                                                <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger
                                                                        Binding="{Binding Status}"
                                                                        Value="{x:Static models:ServiceStatus.Error}">
                                                                        <Setter
                                                                            Property="Visibility"
                                                                            Value="Visible" />
                                                                    </DataTrigger>
                                                                    <DataTrigger
                                                                        Binding="{Binding Status}"
                                                                        Value="{x:Static models:ServiceStatus.Stopped}">
                                                                        <!-- Show "Not Installed"
                                                                        hint even if not in Error
                                                                        state -->
                                                                        <Setter
                                                                            Property="Visibility"
                                                                            Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Right: Panel button (DB services only) + Start/Stop
                                            button with integrated spinner -->
                                            <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center">

                                                <!-- Details button: only visible when service has
                                                an Error -->
                                                <Button Content="Details"
                                                    Visibility="{Binding Status, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Error}"
                                                    Command="{Binding DataContext.ShowDiagnosticsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{DynamicResource Hostix.Button.Ghost}"
                                                    Height="32" Padding="12,0" FontSize="11"
                                                    Margin="0,0,8,0"
                                                    Foreground="{DynamicResource ErrorBrush}" />

                                                <!-- Send Test button: only for Mailpit -->
                                                <Button Content="Send Test"
                                                    Visibility="{Binding Type, Converter={StaticResource StatusToVisibilityConverter}, ConverterParameter=Mailpit}"
                                                    IsEnabled="{Binding Status, Converter={StaticResource StatusToIsEnabledConverter}}"
                                                    Command="{Binding DataContext.SendTestMailCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{DynamicResource Hostix.Button.Ghost}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    Height="32" Padding="12,0" FontSize="11"
                                                    Margin="0,0,8,0" />

                                                <!-- Panel button: only visible when service is Running AND has a panel -->
                                                <Button 
                                                    Command="{Binding DataContext.OpenAdminPanelCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Height="32" Padding="12,0" FontSize="11"
                                                    Margin="0,0,8,0">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource Hostix.Button.Ghost}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Setter Property="Content" Value="Panel" />
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding Status}" Value="{x:Static models:ServiceStatus.Running}" />
                                                                        <Condition Binding="{Binding HasAdminPanel}" Value="True" />
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </MultiDataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="{x:Static models:ServiceType.Mailpit}">
                                                                    <Setter Property="Content" Value="Open Inbox" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <!-- Start/Stop button with integrated spinner —
                                                unchanged -->
                                                <Button
                                                    IsEnabled="{Binding Status, Converter={StaticResource StatusToIsEnabledConverter}}"
                                                    Command="{Binding DataContext.ToggleServiceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Height="32" Padding="14,0" MinWidth="100">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource Hostix.Button.Primary}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:ServiceStatus.Running}">
                                                                    <Setter Property="Background" Value="#27ae60" />
                                                                    <Setter Property="BorderBrush" Value="#2ecc71" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                        <!-- Spinner inside button — only visible
                                                        during Starting/Stopping -->
                                                        <mah:ProgressRing Width="14" Height="14"
                                                            Margin="0,0,6,0"
                                                            Foreground="White">
                                                            <mah:ProgressRing.Style>
                                                                <Style TargetType="mah:ProgressRing">
                                                                    <Setter Property="Visibility"
                                                                        Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger
                                                                            Binding="{Binding Status}"
                                                                            Value="{x:Static models:ServiceStatus.Starting}">
                                                                            <Setter
                                                                                Property="Visibility"
                                                                                Value="Visible" />
                                                                        </DataTrigger>
                                                                        <DataTrigger
                                                                            Binding="{Binding Status}"
                                                                            Value="{x:Static models:ServiceStatus.Stopping}">
                                                                            <Setter
                                                                                Property="Visibility"
                                                                                Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </mah:ProgressRing.Style>
                                                        </mah:ProgressRing>
                                                        <TextBlock
                                                            Text="{Binding Status, Converter={StaticResource StatusToButtonTextConverter}}"
                                                            FontSize="11" FontWeight="Bold"
                                                            VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Empty State -->
                        <StackPanel
                            Visibility="{Binding Services.Count, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"
                            Margin="0,20">
                            <TextBlock Text="No Active Services"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                HorizontalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ===== RIGHT COLUMN: Quick Actions + Runtime Activity ===== -->
                <StackPanel Grid.Column="1" VerticalAlignment="Top">

                    <!-- Quick Actions -->
                    <Border Style="{DynamicResource Hostix.Card}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="QUICK ACTIONS" FontSize="11" FontWeight="Bold"
                                Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,15" />
                            <UniformGrid Columns="2">
                                <Button Content="Stop All Services"
                                    Command="{Binding DataContext.StopAllServicesCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Style="{DynamicResource Hostix.Button.Danger}" Margin="0,0,10,10" />
                                <Button Content="Flush DNS Cache"
                                    Command="{Binding DataContext.FlushDNSCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Style="{DynamicResource Hostix.Button}" Margin="0,0,0,10" />
                                <Button Content="Trust SSL"
                                    Command="{Binding DataContext.TrustRootCACommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Style="{DynamicResource Hostix.Button}" Margin="0,0,10,0"
                                    Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" FontWeight="Bold" />
                                <Button Content="Clear Cache"
                                    Command="{Binding DataContext.ClearCacheCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Style="{DynamicResource Hostix.Button.Ghost}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2"
                                    HorizontalAlignment="Stretch" Margin="0,0,0,0" />
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- Runtime Activity — fixed height, internal modern scrollbar -->
                    <Border Style="{DynamicResource Hostix.Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />  <!-- Header -->
                                <RowDefinition Height="180" />   <!-- Fixed log area — never grows -->
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <TextBlock Grid.Row="0"
                                Text="RUNTIME ACTIVITY" FontSize="11" FontWeight="Bold"
                                Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12" />

                            <!-- Fixed-height scrollable log area with modern scrollbar -->
                            <ScrollViewer Grid.Row="1"
                                Style="{StaticResource ModernScrollViewer}"
                                VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding RuntimeEvents}"
                                    VirtualizingPanel.IsVirtualizing="True"
                                    VirtualizingPanel.VirtualizationMode="Recycling">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Mode=OneWay}"
                                                FontSize="11"
                                                Foreground="{DynamicResource TextSecondaryBrush}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                IsReadOnly="True"
                                                TextWrapping="Wrap"
                                                Margin="0,0,0,6" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>