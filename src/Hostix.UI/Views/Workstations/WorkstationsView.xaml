<UserControl x:Class="Hostix.UI.Views.Workstations.WorkstationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    <Grid Background="Transparent">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,16,24">
                <Grid Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Workstations" Style="{DynamicResource Hostix.Title}" />
                        <TextBlock Text="Next-generation multi-framework development environments (Phase 2 Preview)." 
                                   Style="{DynamicResource Hostix.Subtitle}" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>

                <ItemsControl ItemsSource="{Binding Projects}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBrush}" CornerRadius="12" Padding="24" Margin="0,0,0,16" 
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    SnapsToDevicePixels="True" Effect="{DynamicResource Hostix.Shadow.Small}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding LocalDomain}" FontSize="14" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" Margin="0,8,0,0" />
                                    
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Border Background="#F1F5F9" Padding="8,4" CornerRadius="8">
                                            <TextBlock Text="{Binding Framework.Name}" FontSize="12" FontWeight="Bold" Foreground="#475569" />
                                        </Border>
                                        <Border Background="#F1F5F9" Padding="8,4" CornerRadius="8" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding Framework.Type}" FontSize="12" FontWeight="Bold" Foreground="#475569" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
