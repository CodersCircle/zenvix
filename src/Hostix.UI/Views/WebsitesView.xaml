<UserControl x:Class="Hostix.UI.Views.WebsitesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:models="clr-namespace:Hostix.Core.Models;assembly=Hostix.Core"
    xmlns:conv="clr-namespace:Hostix.UI.Converters"
    mc:Ignorable="d"
    d:DesignHeight="800" d:DesignWidth="1100">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <conv:StatusToColorConverter x:Key="StatusToColorConverter" />
        <conv:StatusToButtonTextConverter x:Key="StatusToButtonTextConverter" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        
        <Style x:Key="ActionIconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <!-- Modern Card Style -->
        <Style x:Key="WebsiteCardStyle" TargetType="Border" BasedOn="{StaticResource Hostix.Card}">
            <Setter Property="Background" Value="{DynamicResource CardBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 1. Header Area -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="Websites" Style="{DynamicResource Hostix.Title}" />
                <TextBlock Text="Local project management and orchestration" 
                           Style="{DynamicResource Hostix.Subtitle}" />
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Command="{Binding ShowAddWebsiteCommand}"
                        Style="{DynamicResource Hostix.Button.Primary}" Height="36" Padding="20,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" VerticalAlignment="Center" FontSize="14" />
                        <TextBlock Text="New Website" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 2. Websites Grid -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Websites}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="280" Margin="0,0,16,16" Background="{DynamicResource CardBrush}" 
                                CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                                SnapsToDevicePixels="True" Effect="{DynamicResource Hostix.Shadow.Small}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /> <!-- Header -->
                                    <RowDefinition Height="Auto" /> <!-- Body -->
                                    <RowDefinition Height="Auto" /> <!-- Tools -->
                                    <RowDefinition Height="Auto" /> <!-- Actions -->
                                </Grid.RowDefinitions>

                                <!-- 1. Status & Meta Row -->
                                <Border Grid.Row="0" Padding="16,16,16,8">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Status Badge -->
                                            <Border Padding="8,4" CornerRadius="12">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F1F5F9" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                <Setter Property="Background" Value="#F0FDF4" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="#94A3B8" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                        <Setter Property="Fill" Value="#22C55E" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#64748B" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Running">
                                                                        <Setter Property="Foreground" Value="#15803D" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>

                                            <!-- SSL Toggle -->
                                            <mah:ToggleSwitch Style="{StaticResource Hostix.ToggleSwitch.Compact}"
                                                              IsOn="{Binding SslEnabled}" 
                                                              Command="{Binding DataContext.ToggleSslCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              CommandParameter="{Binding}"
                                                              OnContent="SSL" OffContent="SSL"
                                                              FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0" />
                                        </StackPanel>

                                        <!-- PHP Version Badge -->
                                        <Border HorizontalAlignment="Right" Background="#F8FAFC" Padding="8,4" CornerRadius="8">
                                            <TextBlock Text="{Binding PhpVersion, StringFormat='PHP {0}'}" FontSize="10" FontWeight="Bold" Foreground="#6366F1" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- 2. Project Identity -->
                                <Border Grid.Row="1" Padding="16,0,16,16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Squircle Icon -->
                                        <Border Width="54" Height="54" CornerRadius="14" Background="{DynamicResource BackgroundBrush}" Margin="0,0,14,0">
                                            <TextBlock Text="{Binding Icon}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" 
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Black" Foreground="{DynamicResource TextPrimaryBrush}" MaxWidth="150" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center" ToolTip="SSL Secure">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                            <Setter Property="Opacity" Value="0.2" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SslEnabled}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                                    <Setter Property="Opacity" Value="1.0" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Domain}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- 3. Quick Tool Actions -->
                                <Border Grid.Row="2" Background="#05000000" BorderThickness="0,1" BorderBrush="{DynamicResource BorderBrush}" Padding="8,8">
                                    <UniformGrid Columns="4">
                                        <Button Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}" ToolTip="Open Folder" Style="{DynamicResource Hostix.Button.Ghost}" Height="34" Padding="0">
                                            <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                                        </Button>
                                        <Button Command="{Binding DataContext.OpenCodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}" ToolTip="Open in VS Code" Style="{DynamicResource Hostix.Button.Ghost}" Height="34" Padding="0">
                                            <TextBlock Text="&#xE799;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                                        </Button>
                                        <Button Command="{Binding DataContext.OpenTerminalCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}" ToolTip="Open Terminal" Style="{DynamicResource Hostix.Button.Ghost}" Height="34" Padding="0">
                                            <TextBlock Text="&#xE756;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                                        </Button>
                                        <Button Command="{Binding DataContext.OpenSiteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}" ToolTip="Open Website" Height="34" Padding="0" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource Hostix.Button.Ghost}">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Running">
                                                            <Setter Property="IsEnabled" Value="True" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="&#xE890;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                                        </Button>
                                    </UniformGrid>
                                </Border>

                                <!-- 4. Primary Actions -->
                                <Border Grid.Row="3" Padding="16,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="10*" />
                                            <ColumnDefinition Width="8*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Run/Stop Button -->
                                        <Button Grid.Column="0" Command="{Binding DataContext.ToggleWebsiteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" IsEnabled="{Binding Status, Converter={StaticResource StatusToIsEnabledConverter}}"
                                                Height="42" Margin="0,0,8,0" Style="{StaticResource Hostix.Button.Blue}">
                                            <StackPanel Orientation="Horizontal">
                                                <mah:ProgressRing Width="14" Height="14" Margin="0,0,8,0" Foreground="White" 
                                                                  Visibility="{Binding Status, Converter={StaticResource StatusToSpinnerVisibilityConverter}}" />
                                                <TextBlock Text="{Binding Status, Converter={StaticResource StatusToButtonTextConverter}}" 
                                                           FontSize="13" FontWeight="Bold" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>

                                        <!-- Remove (Panel) Button -->
                                        <Button Grid.Column="1" Command="{Binding DataContext.DeleteWebsiteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}" Content="Remove" Style="{StaticResource Hostix.Button.Orange}" 
                                                Height="42" Margin="4,0,8,0" />

                                        <!-- Delete (Disk) Button -->
                                        <Button Grid.Column="2" Command="{Binding DataContext.DeleteWebsiteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                CommandParameter="{Binding}" ToolTip="Permanent Delete" Style="{DynamicResource Hostix.Button.Ghost}" 
                                                Width="42" Height="42" Padding="0">
                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource ErrorBrush}" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 3. Add Website Overlay (Themed) -->
        <Border Grid.RowSpan="2" Background="#88000000" Visibility="{Binding IsAddingWebsite, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" Width="820" VerticalAlignment="Center" Padding="35" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.Resources>
                        <!-- Style for Step 1 -->
                        <Style x:Key="Step1VisibilityStyle" TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WizardStep}" Value="1">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                        <!-- Style for Step 2 -->
                        <Style x:Key="Step2VisibilityStyle" TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WizardStep}" Value="2">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                        <!-- Style for Step 3 -->
                        <Style x:Key="Step3VisibilityStyle" TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WizardStep}" Value="3">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                        
                        <!-- Framework-specific Parameter Panels -->
                        <Style x:Key="LaravelParamsVisibilityStyle" TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedFramework}" Value="Laravel">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedFramework}" Value="FilamentPHP">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedFramework}" Value="Laravel API">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                        
                        <Style x:Key="FlutterParamsVisibilityStyle" TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedFramework}" Value="Flutter">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedFramework}" Value="React Native">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedFramework}" Value="Ionic">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>

                        <Style x:Key="DefaultParamsVisibilityStyle" TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedFramework}" Value="Laravel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedFramework}" Value="FilamentPHP">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedFramework}" Value="Laravel API">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedFramework}" Value="Flutter">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedFramework}" Value="React Native">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedFramework}" Value="Ionic">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>

                        <!-- Wizard Card Button Style -->
                        <Style x:Key="WizardCardButton" TargetType="Button" BasedOn="{StaticResource Hostix.Button}">
                            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Padding" Value="16" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="cardBorder" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Stretch" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="cardBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                <Setter TargetName="cardBorder" Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                                <Setter Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Color="Black" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Grid.Resources>
                    
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Create New Zenvix Project" Style="{DynamicResource Hostix.Title}" VerticalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Border Background="{DynamicResource AccentBrush}" Padding="8,4" CornerRadius="6" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding WizardStep, StringFormat='Step {0} of 3'}" FontSize="11" FontWeight="Bold" Foreground="White" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Smart Project Wizard &amp; Dynamic Environment Generator" Style="{DynamicResource Hostix.Subtitle}" Margin="0,4,0,0" />
                            <Separator Background="{DynamicResource BorderBrush}" Margin="0,12,0,0" />
                        </StackPanel>
                    </Grid>

                    <!-- STEP 1: Category Selection -->
                    <Grid Grid.Row="1" Style="{StaticResource Step1VisibilityStyle}">
                        <StackPanel>
                            <TextBlock Text="Select Project Category" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <UniformGrid Columns="2">
                                    <Button Command="{Binding SelectCategoryCommand}" CommandParameter="Website" Style="{StaticResource WizardCardButton}" Height="95" Margin="6">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🌐" FontSize="32" Margin="0,0,16,0" VerticalAlignment="Center" />
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Website" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" />
                                                <TextBlock Text="Laravel, WordPress, React, Vue, PHP" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" MaxWidth="220" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding SelectCategoryCommand}" CommandParameter="Mobile App" Style="{StaticResource WizardCardButton}" Height="95" Margin="6">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📱" FontSize="32" Margin="0,0,16,0" VerticalAlignment="Center" />
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Mobile App" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" />
                                                <TextBlock Text="Flutter, React Native, Ionic previews" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" MaxWidth="220" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding SelectCategoryCommand}" CommandParameter="Admin Panel" Style="{StaticResource WizardCardButton}" Height="95" Margin="6">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📊" FontSize="32" Margin="0,0,16,0" VerticalAlignment="Center" />
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Admin Panel" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" />
                                                <TextBlock Text="FilamentPHP, React or Vue admin portals" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" MaxWidth="220" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding SelectCategoryCommand}" CommandParameter="API Backend" Style="{StaticResource WizardCardButton}" Height="95" Margin="6">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⚡" FontSize="32" Margin="0,0,16,0" VerticalAlignment="Center" />
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="API Backend" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" />
                                                <TextBlock Text="Laravel API, Node.js Express, pure APIs" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" MaxWidth="220" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding SelectCategoryCommand}" CommandParameter="Static Site" Style="{StaticResource WizardCardButton}" Height="95" Margin="6">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📄" FontSize="32" Margin="0,0,16,0" VerticalAlignment="Center" />
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Static Site" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}" />
                                                <TextBlock Text="Plain HTML/CSS, Tailwind starter kits" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" MaxWidth="220" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>
                                </UniformGrid>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- STEP 2: Framework Selection -->
                    <Grid Grid.Row="1" Style="{StaticResource Step2VisibilityStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="Technology Stack for: " FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}" />
                                <TextBlock Text="{Binding SelectedCategory}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="4,0,0,0" />
                            </StackPanel>
                            <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Frameworks}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding}" 
                                                    Command="{Binding DataContext.SelectFrameworkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource WizardCardButton}" 
                                                    Width="170" Height="70" Margin="6" FontSize="13" FontWeight="Bold" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Grid>

                    <!-- STEP 3: Parameter Configuration -->
                    <Grid Grid.Row="1" Style="{StaticResource Step3VisibilityStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <!-- Column 1: General Parameters -->
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="GENERAL PROJECT SETTINGS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12" />
                                
                                <TextBlock Text="PROJECT NAME" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                                <TextBox Text="{Binding NewWebsiteName, UpdateSourceTrigger=PropertyChanged}" 
                                         mah:TextBoxHelper.Watermark="e.g. my-laravel-app" 
                                         mah:ControlsHelper.CornerRadius="8"
                                         Background="{StaticResource SurfaceBrush}" Foreground="Black" BorderBrush="{StaticResource BorderBrush}"
                                         Height="36" Margin="0,0,0,12" Padding="10,0" VerticalContentAlignment="Center" />

                                <TextBlock Text="LOCAL DOMAIN" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="100" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding NewWebsiteDomain, UpdateSourceTrigger=PropertyChanged}" 
                                             mah:TextBoxHelper.Watermark="e.g. myapp.zenvix" 
                                             mah:ControlsHelper.CornerRadius="8,0,0,8"
                                             Background="{StaticResource SurfaceBrush}" Foreground="Black" BorderBrush="{StaticResource BorderBrush}"
                                             Height="36" Padding="10,0" VerticalContentAlignment="Center" />
                                    <ComboBox Grid.Column="1" 
                                              ItemsSource="{Binding Suffixes}" 
                                              SelectedItem="{Binding SelectedSuffix}"
                                              mah:ControlsHelper.CornerRadius="0,8,8,0"
                                              Background="{StaticResource SurfaceBrush}" Foreground="Black" BorderThickness="0,1,1,1" BorderBrush="{StaticResource BorderBrush}"
                                              Height="36" VerticalContentAlignment="Center" />
                                </Grid>

                                <TextBlock Text="WORKSPACE PARENT DIRECTORY" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding NewWebsitePath}" IsReadOnly="True" 
                                             mah:ControlsHelper.CornerRadius="8"
                                             Background="{StaticResource SurfaceBrush}" Foreground="Black" BorderBrush="{StaticResource BorderBrush}"
                                             Height="36" FontSize="11" VerticalContentAlignment="Center" Padding="10,0" />
                                    <Button Grid.Column="1" Command="{Binding BrowseFolderCommand}"
                                            Content="Browse" Style="{DynamicResource Hostix.Button}" 
                                            Height="36" Width="70" Margin="6,0,0,0" Padding="0" />
                                </Grid>

                                <Border Background="{DynamicResource BackgroundBrush}" Padding="8" CornerRadius="6" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Full Workspace Target Path:" FontSize="9" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock Text="{Binding FullCreatedPathDisplay}" FontSize="10" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Divider -->
                            <Separator Grid.Column="1" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="8,0,16,0" Background="{DynamicResource BorderBrush}" />

                            <!-- Column 2: Framework Specific Parameters -->
                            <Grid Grid.Column="2">
                                <!-- Laravel Panel -->
                                <StackPanel Style="{StaticResource LaravelParamsVisibilityStyle}">
                                    <TextBlock Text="LARAVEL CONFIGURATIONS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12" />

                                    <TextBlock Text="PHP VERSION" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                                    <ComboBox SelectedItem="{Binding LaravelPhpVersion}" mah:ControlsHelper.CornerRadius="8" Height="36" Margin="0,0,0,12" VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="8.3" IsSelected="True" />
                                        <ComboBoxItem Content="8.2" />
                                        <ComboBoxItem Content="8.1" />
                                    </ComboBox>

                                    <TextBlock Text="LOCAL DATABASE ENGINE" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                                    <ComboBox SelectedItem="{Binding LaravelDatabase}" mah:ControlsHelper.CornerRadius="8" Height="36" Margin="0,0,0,12" VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="SQLite" IsSelected="True" />
                                        <ComboBoxItem Content="MySQL" />
                                    </ComboBox>

                                    <TextBlock Text="TESTING FRAMEWORK" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                                    <ComboBox SelectedItem="{Binding LaravelTestingFramework}" mah:ControlsHelper.CornerRadius="8" Height="36" Margin="0,0,0,16" VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="Pest" IsSelected="True" />
                                        <ComboBoxItem Content="PHPUnit" />
                                    </ComboBox>

                                    <mah:ToggleSwitch Header="Authentication Starter Kit" IsOn="{Binding LaravelAuthEnabled}" 
                                                      Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" Margin="0,0,0,8" 
                                                      OnContent="Laravel Breeze" OffContent="None" />
                                                      
                                    <mah:ToggleSwitch Header="Team Management Support" IsOn="{Binding LaravelTeamsEnabled}" 
                                                      Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" Margin="0,0,0,8" 
                                                      OnContent="Jetstream Teams" OffContent="Standard Users" />
                                </StackPanel>

                                <!-- Flutter Panel -->
                                <StackPanel Style="{StaticResource FlutterParamsVisibilityStyle}">
                                    <TextBlock Text="FLUTTER CONFIGURATIONS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12" />

                                    <TextBlock Text="STATE MANAGEMENT" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                                    <ComboBox SelectedItem="{Binding FlutterStateManagement}" mah:ControlsHelper.CornerRadius="8" Height="36" Margin="0,0,0,12" VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="Provider" IsSelected="True" />
                                        <ComboBoxItem Content="Riverpod" />
                                        <ComboBoxItem Content="Bloc" />
                                        <ComboBoxItem Content="None" />
                                    </ComboBox>

                                    <TextBlock Text="TARGET PLATFORMS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" />
                                    <CheckBox Content="Android Support" IsChecked="{Binding FlutterAndroidSupport}" Margin="0,0,0,6" Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <CheckBox Content="iOS Support" IsChecked="{Binding FlutterIosSupport}" Margin="0,0,0,6" Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <CheckBox Content="Web Preview (Localhost)" IsChecked="{Binding FlutterWebSupport}" Margin="0,0,0,16" Foreground="{DynamicResource TextPrimaryBrush}" />

                                    <mah:ToggleSwitch Header="Local Developer Documentation" IsOn="{Binding CreateDocsSite}" 
                                                      Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" Margin="0,0,0,8" 
                                                      OnContent="Generate docs.zenvix" OffContent="No Docs" />
                                </StackPanel>

                                <!-- Default/Static/React Panel -->
                                <StackPanel Style="{StaticResource DefaultParamsVisibilityStyle}">
                                    <TextBlock Text="WORKSPACE SETTINGS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12" />

                                    <mah:ToggleSwitch Header="Local Developer Documentation" IsOn="{Binding CreateDocsSite}" 
                                                      Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" Margin="0,0,0,12" 
                                                      OnContent="docs.zenvix enabled" OffContent="No Docs" />
                                                      
                                    <mah:ToggleSwitch Header="Git Repository Initialization" IsOn="{Binding GitInitEnabled}" 
                                                      Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" Margin="0,0,0,12" 
                                                      OnContent="git init" OffContent="Manual Git" />

                                    <mah:ToggleSwitch Header="Enable SSL (HTTPS)" IsOn="{Binding NewWebsiteSslEnabled}" 
                                                      Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" Margin="0,0,0,12" 
                                                      OnContent="Secure HTTPS" OffContent="Insecure HTTP" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>

                    <!-- Footer Controls -->
                    <Grid Grid.Row="2" Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Back" Command="{Binding GoBackCommand}" 
                                Width="90" Height="34" Padding="0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource Hostix.Button}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding WizardStep}" Value="1">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="Cancel" Command="{Binding CancelAddWebsiteCommand}" 
                                    Style="{DynamicResource Hostix.Button.Ghost}" Margin="0,0,12,0" Width="90" Height="34" />
                            <Button Content="Next Step" Command="{Binding GoForwardCommand}" 
                                    Width="120" Height="34">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource Hostix.Button.Primary}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WizardStep}" Value="3">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="Create Project" Command="{Binding CreateWebsiteCommand}" 
                                    Width="140" Height="34" Background="{DynamicResource SuccessBrush}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource Hostix.Button.Primary}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WizardStep}" Value="3">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>