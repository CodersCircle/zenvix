<mah:MetroWindow x:Class="Hostix.UI.Views.RemoveConfirmationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:ds="clr-namespace:Zenvix.DesignSystem"
        Title="REMOVE PROJECT FROM PANEL" Height="280" Width="480"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource Zenvix.Background}"
        BorderThickness="1" BorderBrush="{StaticResource Zenvix.Border}"
        GlowBrush="{StaticResource Zenvix.BorderGlow}"
        TitleCharacterCasing="Normal"
        TitleAlignment="Left">
    
    <Grid>
        <StackPanel Margin="32,24" VerticalAlignment="Center">
            <!-- Warning Title & Icon -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <!-- SVG Icon rendering via static resource path -->
                <Path Data="{StaticResource HeroIcon.Trash}" Fill="{StaticResource Zenvix.Warning}" Width="32" Height="32" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,16,0" />
                <TextBlock Text="Remove Project from Panel" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Zenvix.TextPrimary}" VerticalAlignment="Center" />
            </StackPanel>
            
            <!-- Message Body -->
            <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="22" Foreground="{StaticResource Zenvix.TextSecondary}" Margin="0,0,0,28">
                Are you sure you want to remove <Run FontWeight="Bold" Foreground="{StaticResource Zenvix.Accent}" Text="{Binding WebsiteName, Mode=OneWay}" /> from the Zenvix workstation panel?
                <LineBreak />
                <Run FontWeight="SemiBold" Foreground="{StaticResource Zenvix.Warning}">Note:</Run> Your project files on disk will <Run FontWeight="Bold" Foreground="{StaticResource Zenvix.Warning}">NOT</Run> be deleted.
            </TextBlock>

            <!-- Actions Row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="130" />
                </Grid.ColumnDefinitions>
                
                <ds:ZenvixButton Grid.Column="1" Content="Yes, Remove" Command="{Binding ConfirmCommand}" 
                        Style="{StaticResource ZenvixButton.Primary}" Height="40" FontSize="13" FontWeight="SemiBold" />

                <ds:ZenvixButton Grid.Column="3" Content="Cancel" Command="{Binding CancelCommand}" 
                        Style="{StaticResource ZenvixButton}" Height="40" FontSize="13" FontWeight="SemiBold" />
            </Grid>
            
        </StackPanel>
    </Grid>
</mah:MetroWindow>
